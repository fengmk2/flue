---
interface Props {
	sectionTitle: string;
}

const { sectionTitle } = Astro.props;
---

<summary class="flex cursor-pointer list-none items-center justify-between py-3 px-4 text-sm font-medium text-docs-muted [&::-webkit-details-marker]:hidden">
	<span>{sectionTitle} menu</span>
	<svg class="w-4 fill-none stroke-current [stroke-linecap:round] [stroke-linejoin:round] [stroke-width:1.6] transition-transform duration-150 group-open:rotate-180" viewBox="0 0 20 20" aria-hidden="true"><path d="m5 7.5 5 5 5-5" /></svg>
</summary>
